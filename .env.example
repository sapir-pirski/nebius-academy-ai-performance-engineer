# LLM provider keys (set one or both)
OPENAI_API_KEY=
NEBIUS_API_KEY=

# Optional provider tuning
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1
LOG_DIR=logs
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.0

# Optional GitHub token to reduce rate limit errors
GITHUB_TOKEN=
GITHUB_MAX_RETRIES=3
GITHUB_RETRY_BACKOFF_SECONDS=0.5
